# ---- Flutter / Dart ----
app/.dart_tool/
app/.flutter-plugins
app/.flutter-plugins-dependencies
app/.packages
app/build/
app/.pub-cache/
app/.pub/
**/*.g.dart.lock
**/doc/api/
**/.fvm/
*.lock.bak

# Generated code is committed; build artifacts are not
app/android/.gradle/
app/android/app/debug/
app/android/app/profile/
app/android/app/release/
app/android/local.properties
app/android/key.properties
app/android/**/GeneratedPluginRegistrant.*
app/ios/Flutter/Flutter.framework
app/ios/Flutter/Flutter.podspec
app/ios/Pods/
app/ios/.symlinks/
app/ios/Runner.xcworkspace/xcuserdata/
app/macos/Pods/
app/macos/Flutter/ephemeral/
app/windows/flutter/ephemeral/
app/**/Generated.xcconfig
app/**/flutter_export_environment.sh

# ---- Firebase secrets (do NOT commit) ----
**/google-services.json
**/GoogleService-Info.plist
**/firebase_options.dart
**/.firebaserc
**/firebase-debug.log
**/serviceAccountKey*.json

# ---- Node / website / extension ----
node_modules/
website/.next/
website/out/
website/dist/
website/.vercel/
extension/ui/
extension/*.zip
.env
.env.*
!.env.example

# ---- Signing / certs ----
*.keystore
*.jks
*.p12
*.mobileprovision
*.cer

# ---- OS / editor ----
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/*
!.vscode/launch.json
!.vscode/settings.shared.json

# ---- Setup logs (keep script, ignore logs) ----
_setup/*.log
_setup/install.DONE
_setup/install.FAILED
_setup/android.DONE
_setup/android_fix.DONE
_setup/shots/
_setup/chromeprofile/

# Agent worktrees (git-managed; never track)
.claude/worktrees/
